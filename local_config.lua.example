-- local_config.lua.example
-- Copy this file into your Neovim config as a lazy.nvim plugin spec.
-- All settings are changed by editing this file — no separate config files needed.
--
-- After installing, run  :checkhealth llm  to verify curl / API keys / endpoints.

return {
	{ -- llm.nvim: streaming LLM completions + code editing inside Neovim
		"Chunt0/llm.nvim",
		dependencies = { "nvim-lua/plenary.nvim" },
		config = function()
			-- ================================================================
			-- CONFIGURATION
			-- All options are optional — anything omitted keeps its default.
			-- ================================================================
			require("llm").setup({

				-- ── Keymaps ──────────────────────────────────────────────────
				-- true registers the full built-in <leader> set:
				--   <leader>l… Ollama   <leader>a… Anthropic   <leader>o… OpenAI
				--   (i invoke, c code, b code+bufs, t chat, a chat+bufs, d diff)
				--   <leader>z… shared: zz reset, zc/zx/zl context, zm memory, zh health
				-- Prefer your own maps? Set false and bind manually (see below).
				default_keymaps = true,

				constants = {
					-- ── Models ────────────────────────────────────────────────
					models = {
						ollama = "qwen3.6:latest",
						-- Any model pulled on your Ollama instance, e.g. "gemma4:26b".
						-- List what's available:  curl http://localhost:11434/api/tags

						anthropic = "claude-haiku-4-5",
						-- options: "claude-haiku-4-5", "claude-sonnet-4-6",
						--          "claude-sonnet-5", "claude-opus-4-8"

						openai = "gpt-5.4-mini",
					},

					-- ── API Endpoints ─────────────────────────────────────────
					-- Ollama defaults to your local instance. To use a remote /
					-- personal server instead, uncomment and point it there:
					-- api_endpoints = {
					--   ollama = "https://ollama.putty-ai.com/api/chat",
					-- },

					-- ── Prompts ───────────────────────────────────────────────
					-- Override any or all prompts. Omit a key to keep the default.
					--
					--   system_prompt    → used in invoke and code_chat modes
					--   code_prompt      → system prompt for code / code_all_buf / code_diff
					--                      (should instruct raw code output only)
					--   code_instruction → prefix prepended to the user prompt in code modes;
					--                      your selected text is appended after this
					--
					-- prompts = {
					--   system_prompt    = "You are a helpful assistant. Be concise.",
					--   code_prompt      = "You are a code-replacement engine. Output ONLY raw source code — no markdown, no fences, no explanations.",
					--   code_instruction = "OUTPUT ONLY RAW CODE — no markdown fences, no backticks. Task:\n",
					-- },

					-- ── Generation parameters ─────────────────────────────────
					-- vars = {
					--   max_tokens       = 16000, -- response cap (Anthropic default 16000)
					--   reasoning_effort = "low", -- OpenAI Responses reasoning effort
					-- },
				},

				-- ── UI ────────────────────────────────────────────────────────
				ui = {
					mode = "inline", -- "inline" | "float" | "split"
					throttle_ms = 20, -- stream write batching interval in ms
				},

				-- ── Conversation memory ───────────────────────────────────────
				memory = {
					enabled = true,
					max_messages = 20, -- turns kept per buffer (older turns dropped)
				},

				-- ── Context picker ────────────────────────────────────────────
				context = {
					max_buffer_bytes = 200 * 1024, -- skip buffers larger than this
					include_filetypes = nil, -- allowlist e.g. { "lua", "ts", "py" }
				},

				-- ── Network ───────────────────────────────────────────────────
				network = {
					max_time = 120, -- curl --max-time (seconds)
					retry = 2, -- curl --retry count
				},

				-- ── Logging ───────────────────────────────────────────────────
				logging = {
					enabled = false, -- or set LLM_LOG=1 in your environment
					redact = true, -- truncate prompts/responses in log entries
				},

				-- ── Diff accept / reject keymaps ──────────────────────────────
				-- Active only while a diff split is open (buffer-local).
				keymaps = {
					diff_accept = "<leader>da",
					diff_reject = "<leader>dr",
				},
			})

			-- ================================================================
			-- PROJECT MEMORY  (:LLMMemoryEdit)
			--
			-- Create a file called  llm_memory.md  in your project root.
			-- Its contents are automatically prepended to the system prompt on
			-- every request — giving the LLM persistent context about your code.
			-- ================================================================

			-- ================================================================
			-- CUSTOM KEY MAPPINGS
			--
			-- With default_keymaps = true the maps below are already set.
			-- To customise, set default_keymaps = false and bind what you want:
			--
			-- local ollama    = require("llm.ollama")
			-- local anthropic = require("llm.anthropic")
			-- local openai    = require("llm.openai")
			--
			-- vim.keymap.set({ "n", "v" }, "<leader>li", ollama.invoke,            { desc = "LLM Ollama: Invoke" })
			-- vim.keymap.set("v",          "<leader>lc", ollama.code,              { desc = "LLM Ollama: Code (replace selection)" })
			-- vim.keymap.set("v",          "<leader>lb", ollama.code_all_buf,      { desc = "LLM Ollama: Code (all buffers)" })
			-- vim.keymap.set({ "n", "v" }, "<leader>lt", ollama.code_chat,         { desc = "LLM Ollama: Code chat" })
			-- vim.keymap.set({ "n", "v" }, "<leader>la", ollama.code_chat_all_buf, { desc = "LLM Ollama: Code chat (all buffers)" })
			-- vim.keymap.set("v",          "<leader>ld", ollama.code_diff,         { desc = "LLM Ollama: Code diff" })
			-- ================================================================
		end,
	},
}
